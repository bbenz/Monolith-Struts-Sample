spring:
  application:
    name: skishop-app
  datasource:
    url: jdbc:postgresql://${DB_HOST:localhost}:${DB_PORT:5432}/${DB_NAME:skishop}
    username: ${DB_USERNAME:${DB_USER:postgres}}
    password: ${DB_PASSWORD:your-database-password}
    driver-class-name: org.postgresql.Driver
    hikari:
      maximum-pool-size: 10
      minimum-idle: 5
      connection-timeout: 30000
  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.PostgreSQLDialect
  thymeleaf:
    cache: false

openai:
  endpoint: ${OPENAI_ENDPOINT:https://your-azure-openai-resource.cognitiveservices.azure.com/openai/v1/}
  apikey: ${OPENAI_APIKEY:your-azure-openai-api-key-here}
  deployment: ${OPENAI_DEPLOYMENT:your-deployment-name}

# Weather Service Configuration (Open-Meteo API)
weather:
  service:
    mode: ${WEATHER_MODE:real}  # Set to 'mock' for testing, 'real' for production
  fallback:
    enabled: ${WEATHER_FALLBACK:true}  # Fall back to mock if API fails

logging:
  level:
    com.skishop: DEBUG
    org.springframework: INFO
    org.hibernate.SQL: DEBUG

management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics,prometheus
  endpoint:
    health:
      show-details: when_authorized
    prometheus:
      enabled: true
  metrics:
    tags:
      application: ${spring.application.name}
    export:
      prometheus:
        enabled: true
